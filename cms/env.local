# Local env for the CMS (Next.js loads .env.local automatically). Gitignored.

# ─── Shared SQLite DB (same file the Node showcase server owns) ───
# Used when the CMS runs co-located with the server (reads the file directly).
DB_PATH=../server/data/showcase.sqlite

# ─── Box server (on-device Node) ─────────────────────────────────
# The Android box hosting the live server over LAN. When the CMS runs on a
# separate machine from the box, point it here and read/write via the HTTP API
# instead of the local DB file (see cms/src/lib — API-mode wiring).
BOX_API_URL=http://10.0.1.45:3000

# ─── Cloudflare R2 (S3-compatible) media storage ─────────────────
# Account access keys + endpoint are reused from before. Create a NEW bucket in
# the Cloudflare dashboard, then update R2_BUCKET_NAME below and, after you
# enable public access on it, paste its public URL into R2_PUBLIC_URL.
R2_BUCKET_NAME=fashionapp
R2_ACCESS_KEY_ID=5033f8f65049d79d7a9f1adceaecea58
R2_SECRET_ACCESS_KEY=57ae9d11cf898cfafe556c459b3576fbaac0ef6b4cad47f0d2fec6fcb271637b
R2_ENDPOINT=https://ee45a8b4ea3582c0dd04eadacd156d1e.r2.cloudflarestorage.com
# TODO: replace with the NEW bucket's public dev URL (https://pub-<hash>.r2.dev)
R2_PUBLIC_URL=https://pub-523820920dc64084bb06c0d1dd884d90.r2.dev

# ─── AI enrichment (Anthropic Claude, vision) ────────────────────
# TODO: add your Anthropic API key
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8

# Media served from the box (public var for the browser)
NEXT_PUBLIC_BOX_API_URL=http://10.0.1.45:3000
