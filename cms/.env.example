# ─── Shared SQLite DB (the same file the Node showcase server owns) ───
# Absolute path or relative to the cms/ working dir. Defaults to ../server/data/showcase.sqlite
DB_PATH=../server/data/showcase.sqlite

# ─── Box server (on-device Node) over LAN ────────────────────────────
# The Android box hosting the live server. Set this when the CMS runs on a
# different machine than the box (read/write via the HTTP API instead of the
# local DB file). Use the box's LAN IP — not a secret, safe to share.
BOX_API_URL=http://10.0.1.45:3000

# ─── Cloudflare R2 (S3-compatible) media storage ─────────────────────
R2_BUCKET_NAME=essonify
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://pub-<hash>.r2.dev

# ─── AI enrichment (Anthropic Claude, vision) ────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
# Optional model override (defaults to claude-opus-4-8)
AI_MODEL=claude-opus-4-8
# Browser-visible origin for /media/* (the box serves the images)
NEXT_PUBLIC_BOX_API_URL=http://10.0.1.45:3000
